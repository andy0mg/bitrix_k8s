---
# cp inventory/hosts.yml.example inventory/hosts.yml
#
# Не делайте так (будет warning «unexpected key ansible_controller»):
#   all:
#     ansible_controller: ...
# Нужно только: all → children → ansible_controller → hosts → deploy
#
# ansible_controller — отдельная группа (как k8s_*).
all:
  vars:
    ansible_user: ubuntu
  children:
    ansible_controller:
      hosts:
        deploy:
          ansible_host: 127.0.0.1
          ansible_connection: local
    k8s_control:
      hosts:
        cp-1:
          ansible_host: 10.0.0.10
    k8s_workers:
      hosts:
        worker-1:
          ansible_host: 10.0.0.11
        worker-2:
          ansible_host: 10.0.0.12
    nfs_server:
      hosts:
        nfs-1:
          ansible_host: 10.0.0.20
