---
# cp inventory/hosts.yml.example inventory/hosts.yml
all:
  vars:
    ansible_user: ubuntu
  hosts:
    # Нужен для плеев с hosts: localhost (addons, bitrix): без него не подгружается group_vars/all.yml
    ansible_controller:
      ansible_host: 127.0.0.1
      ansible_connection: local
  children:
    k8s_control:
      hosts:
        cp-1:
          ansible_host: 10.0.0.10
    k8s_workers:
      hosts:
        worker-1:
          ansible_host: 10.0.0.11
        worker-2:
          ansible_host: 10.0.0.12
    nfs_server:
      hosts:
        nfs-1:
          ansible_host: 10.0.0.20
