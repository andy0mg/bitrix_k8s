# Сгенерировано Ansible (ingress_nginx_on_control_plane)
{% if ingress_nginx_on_control_plane | default(true) | bool %}
controller:
  # Только control-plane ноды (иначе с taint под не попадёт без tolerations)
  nodeSelector:
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule
  # Helm ждёт pre-install Job патча webhook; без tolerations Job висит в Pending на закинутом master
  admissionWebhooks:
    patch:
      nodeSelector:
        node-role.kubernetes.io/control-plane: ""
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule
{% else %}
{}
{% endif %}
