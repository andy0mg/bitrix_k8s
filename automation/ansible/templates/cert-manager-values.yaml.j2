# Сгенерировано Ansible. Только при cert_manager_on_control_plane: true — привязка к master.
# Не наследуем от ingress: при ingress на CP и cert-manager на CP webhook часто не становится Ready (CPU/taint).
{% if cert_manager_on_control_plane | default(false) | bool %}
# Сохраняем kubernetes.io/os: linux из дефолтов чарта + CP
nodeSelector:
  kubernetes.io/os: linux
  node-role.kubernetes.io/control-plane: ""
tolerations:
  - key: node-role.kubernetes.io/control-plane
    operator: Exists
    effect: NoSchedule
  - key: node-role.kubernetes.io/master
    operator: Exists
    effect: NoSchedule

webhook:
  nodeSelector:
    kubernetes.io/os: linux
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule

cainjector:
  nodeSelector:
    kubernetes.io/os: linux
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule

startupapicheck:
  nodeSelector:
    kubernetes.io/os: linux
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule
{% else %}
# Явно снять привязку к CP (иначе helm upgrade оставляет старые nodeSelector от прошлого релиза).
nodeSelector: {}
tolerations: []
webhook:
  nodeSelector: {}
  tolerations: []
cainjector:
  nodeSelector: {}
  tolerations: []
startupapicheck:
  nodeSelector: {}
  tolerations: []
{% endif %}
