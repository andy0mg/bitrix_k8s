# Сгенерировано Ansible. Привязка к master только если задано cert_manager_on_control_plane: true
# или (по умолчанию) если k8s_join_workers: false — один master без воркеров.
# Не наследуем от ingress: при workers и ingress на CP cert-manager на том же CP часто даёт webhook 0/1.
{% set _cm_pin_cp = (cert_manager_on_control_plane
  if cert_manager_on_control_plane is defined
  else not (k8s_join_workers | default(false) | bool)) | bool %}
{% if _cm_pin_cp %}
# Сохраняем kubernetes.io/os: linux из дефолтов чарта + CP
nodeSelector:
  kubernetes.io/os: linux
  node-role.kubernetes.io/control-plane: ""
tolerations:
  - key: node-role.kubernetes.io/control-plane
    operator: Exists
    effect: NoSchedule
  - key: node-role.kubernetes.io/master
    operator: Exists
    effect: NoSchedule

webhook:
  nodeSelector:
    kubernetes.io/os: linux
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule

cainjector:
  nodeSelector:
    kubernetes.io/os: linux
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule

startupapicheck:
  nodeSelector:
    kubernetes.io/os: linux
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule
{% else %}
# Явно снять привязку к CP (иначе helm upgrade оставляет старые nodeSelector от прошлого релиза).
nodeSelector: {}
tolerations: []
webhook:
  nodeSelector: {}
  tolerations: []
cainjector:
  nodeSelector: {}
  tolerations: []
startupapicheck:
  nodeSelector: {}
  tolerations: []
{% endif %}
