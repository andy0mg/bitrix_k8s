# Сгенерировано Ansible — single control-plane с taint
{% if nfs_provisioner_on_control_plane | default(ingress_nginx_on_control_plane | default(true)) | bool %}
nodeSelector:
  kubernetes.io/os: linux
  node-role.kubernetes.io/control-plane: ""
tolerations:
  - key: node-role.kubernetes.io/control-plane
    operator: Exists
    effect: NoSchedule
  - key: node-role.kubernetes.io/master
    operator: Exists
    effect: NoSchedule
{% else %}
{}
{% endif %}
