global:
  domain: {{ bitrix_domain | quote }}
  storageClass:
    rwx: {{ bitrix_storage_rwx | quote }}
    rwo: {{ (bitrix_storage_rwo | default(bitrix_storage_rwx, true)) | quote }}
{% if ingress_nginx_on_control_plane | default(false) | bool %}
  nodeSelector:
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule
{% endif %}

createNamespace: false

ingress:
  enabled: true
  className: nginx
  tls:
    enabled: {{ ingress_tls_enabled | bool }}
    secretName: {{ ingress_tls_secret | quote }}
    certManager:
      enabled: {{ ingress_cert_manager_annotation | bool }}
      clusterIssuer: {{ letsencrypt_cluster_issuer | quote }}

certManager:
  createClusterIssuer: {{ bitrix_create_cluster_issuer | bool }}
  clusterIssuer:
    name: {{ letsencrypt_cluster_issuer | quote }}
    email: {{ letsencrypt_email | quote }}
    server: https://acme-v02.api.letsencrypt.org/directory
