{# Только явный bitrix_on_control_plane: true — Bitrix на master (taint). Ingress на CP (ingress_nginx_on_control_plane) сюда НЕ входит: при workers поды идут на workers. #}
{% set _bitrix_on_cp = (bitrix_on_control_plane | default(false)) | bool %}
global:
  domain: {{ bitrix_domain | quote }}
  storageClass:
    rwx: {{ bitrix_storage_rwx | quote }}
    rwo: {{ (bitrix_storage_rwo | default(bitrix_storage_rwx, true)) | quote }}
{% if _bitrix_on_cp %}
  nodeSelector:
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule
{% endif %}
{% if _bitrix_on_cp %}
# Одна нода CP: 3×web + HPA часто даёт Pending (insufficient cpu/memory)
web:
  replicaCount: {{ bitrix_web_replicas | default(1) | int }}
hpa:
  enabled: {{ bitrix_hpa_enabled | default(false) | bool }}
{% endif %}

createNamespace: false

ingress:
  enabled: true
  className: nginx
  tls:
    enabled: {{ ingress_tls_enabled | bool }}
    secretName: {{ ingress_tls_secret | quote }}
    certManager:
      enabled: {{ ingress_cert_manager_annotation | bool }}
      clusterIssuer: {{ letsencrypt_cluster_issuer | quote }}

certManager:
  createClusterIssuer: {{ bitrix_create_cluster_issuer | bool }}
  clusterIssuer:
    name: {{ letsencrypt_cluster_issuer | quote }}
    email: {{ letsencrypt_email | quote }}
    server: https://acme-v02.api.letsencrypt.org/directory
